.chroma/
.duckdb/
*.db
*.sqlite
*.index
data/vector_store/

# AI Agent Telemetry & Observability (Phoenix, LangSmith local caches)
.phoenix/
.langchain/
*.log
agent_run_*.json

# Large AI Assets
*.bin
*.onnx
*.pkl
*.pickle
models/
downloads/

# === Environment Secrets (CRITICAL for API Keys) ===
.env
.env.*
!.env.example
secrets.toml
*.pem
*.key

# === IDEs & System Files ===
.vscode/
.idea/
.DS_Store
Thumbs.db

